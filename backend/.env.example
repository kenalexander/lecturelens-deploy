# Default: OpenAI (recommended)
NOTES_MODE=llm
DISABLE_RULES=1
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
OPENAI_TIMEOUT_SECONDS=30
FLASHCARDS_TIMEOUT_SECONDS=75
FLASHCARDS_SOURCE_MAX_CHARS=9000
# Auth / DB
JWT_SECRET=change-me
JWT_EXPIRES_DAYS=7
DB_PATH=data/lecturelens.db
# Leave DATABASE_URL unset for local SQLite development.
DATABASE_URL=
COOKIE_SECURE=0
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000

# Notes tick
NOTES_TICK_SECONDS=15

# LLM batching / gating (Phase 1)
WARMUP_MIN_CHARS=1200
UPDATE_MIN_CHARS=400
MAX_INPUT_NEW_CHARS=1800
MAX_WAIT_SECONDS=45
MIN_TIME_FALLBACK_CHARS=250
MEMORY_MAX_CHARS=1200

# Live + Final notes
LIVE_NOTES_INTERVAL_SECONDS=10
MAX_LIVE_NOTES_CHARS=1200
MAX_FINAL_TRANSCRIPT_CHARS=12000
MAX_STUDENT_NOTES_CHARS=4000
FINAL_NOTES_TIMEOUT_SECONDS=90
FINAL_NOTES_RETRIES=2

# Debug
DEBUG_LLM=0
DEBUG_NOTES=0

# Whisper model
WHISPER_MODEL=small.en

# Optional Ollama config (uncomment to use)
# LLM_PROVIDER=ollama
# LLM_HTTP_URL=http://localhost:11434
# LLM_MODEL=llama3.1:8b
